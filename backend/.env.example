# SiftPlace backend configuration — copy to .env (or export in your shell).
# EVERY key is optional: unset providers/features are skipped gracefully.
# Backend-only: none of these ever reach the browser. Never commit real values.

# --- Affiliate listings providers (real prices + tracked booking links) -------
# Travelpayouts / Hotellook (free programme: travelpayouts.com)
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# Hotelbeds APItude (sandbox until certified; base URL overridable)
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
# HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com

# Agoda affiliate (dormant until the account is approved)
AGODA_API_KEY=
AGODA_SITE_ID=

# Expedia EPS Rapid (dormant until the partner contract exists)
EXPEDIA_API_KEY=
EXPEDIA_SHARED_SECRET=

# --- NLP ("anything else?" parsing) --------------------------------------------
# When set, the free-text parser uses an LLM; otherwise the built-in
# keyword-rules parser runs (always available as the fallback).
ANTHROPIC_API_KEY=
# SIFTPLACE_NLP_MODEL=claude-haiku-4-5-20251001

# --- Bot protection -------------------------------------------------------------
# Optional Cloudflare Turnstile human check on /search (never a signup gate).
# Set the secret here and VITE_TURNSTILE_SITE_KEY in app/.env.
TURNSTILE_SECRET_KEY=

# Per-IP rate limits (slowapi syntax)
# SIFTPLACE_SEARCH_LIMIT=15/minute
# SIFTPLACE_PARSE_LIMIT=30/minute
# SIFTPLACE_GEOCODE_LIMIT=30/minute
