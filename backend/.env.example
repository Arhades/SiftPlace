# SiftPlace backend configuration — copy to .env (or export in your shell).
# EVERY key is optional: unset providers/features are skipped gracefully.
# Backend-only: none of these ever reach the browser. Never commit real values.

# --- Affiliate listings providers (real prices + tracked booking links) -------
# Travelpayouts / Hotellook (free programme: travelpayouts.com)
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# Hotelbeds APItude (sandbox until certified; base URL overridable)
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
# HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com

# Agoda affiliate (dormant until the account is approved)
AGODA_API_KEY=
AGODA_SITE_ID=

# Expedia EPS Rapid (dormant until the partner contract exists)
EXPEDIA_API_KEY=
EXPEDIA_SHARED_SECRET=

# --- NLP ("anything else?" parsing) --------------------------------------------
# No key needed: the parser is keyword rules (nlp_terms.csv) plus a locally
# TRAINED classifier (nlp_model.joblib). Retrain on accumulated notes with
# `python nlp_train.py` or POST /admin/retrain — see nlp.py.
# Privacy kill switch: set to 1 to never store submitted notes as training data
# (users can also opt out per request; POST /notes/delete removes stored notes).
# NLP_TRAINING_DISABLED=

# --- Sift mascot chat: LLM chain (llm.py) ----------------------------------------
# Chain: Agnes AI (primary — competition criterion) -> OpenAI -> offline nlp.py.
# All optional: with no keys the mascot still works on the rules engine.
# Agnes AI (agnes-ai.com, Singapore). OpenAI-compatible chat endpoint; adjust
# AGNES_API_URL/AGNES_MODEL to match their current docs if they differ.
AGNES_API_KEY=
# AGNES_API_URL=https://api.agnes-ai.com/v1/chat/completions
# AGNES_MODEL=agnes-chat
OPENAI_API_KEY=
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-4o-mini

# --- Semantic search on GMI Cloud (semantic.py) ----------------------------------
# Embedding model hosted with the competition's GMI (Nvidia GPU) credits behind
# an OpenAI-compatible /v1/embeddings endpoint. Unset = keyword engine only.
GMI_API_KEY=
# GMI_EMBED_URL=https://api.gmi-serving.com/v1/embeddings
# GMI_EMBED_MODEL=BAAI/bge-m3
# blend: final = (1-w)*keyword + w*semantic (0..0.8)
# SEMANTIC_WEIGHT=0.3
# set to 1 to add an LLM "why this matches" line per result (extra latency+cost)
# SEMANTIC_EXPLAIN=

# --- CORS ------------------------------------------------------------------------
# Comma-separated allowlist of frontend origins. Default: the deployed Vercel
# app + localhost dev ports. "*" re-opens everything (dev only).
# SIFTPLACE_ALLOWED_ORIGINS=https://sift-place.vercel.app,http://localhost:5173

# --- Founder admin ---------------------------------------------------------------
# Required to open /admin (usage dashboard) and /admin/retrain. Verified
# server-side with a constant-time compare; unset = admin disabled.
ADMIN_TOKEN=
# Salt for the hashed IPs in the usage log (rotate to unlink history)
# SIFTPLACE_IP_SALT=change-me

# --- Bot protection -------------------------------------------------------------
# Optional Cloudflare Turnstile human check on /search (never a signup gate).
# Set the secret here and VITE_TURNSTILE_SITE_KEY in app/.env.
TURNSTILE_SECRET_KEY=

# Per-IP rate limits (slowapi syntax). Search allows page flips.
# SIFTPLACE_SEARCH_LIMIT=30/minute
# SIFTPLACE_PARSE_LIMIT=30/minute
# SIFTPLACE_GEOCODE_LIMIT=30/minute
# SIFTPLACE_CHAT_LIMIT=20/minute
# SIFTPLACE_FEEDBACK_LIMIT=10/minute
