# Where the SiftPlace FastAPI backend is reachable.
# Dev default below; set to your deployed URL in production.
VITE_API_URL=http://localhost:8000

# Optional Cloudflare Turnstile human check on searches (pairs with the
# backend's TURNSTILE_SECRET_KEY). Leave empty to disable — the app never
# requires an account either way.
VITE_TURNSTILE_SITE_KEY=

# Community listing reviews (Supabase — the repurposed waitlist project).
# Project URL + PUBLIC anon key; Row Level Security guards the table
# (run docs/supabase-community.sql once). Empty = feature hidden.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Travelpayouts affiliate tracking for the pre-departure checklist links.
# marker = your account id, trs = traffic-source id (dashboard → Tools →
# Link generator). Empty = links still work, just uncredited. Program ids
# live in src/lib/affiliates.ts.
VITE_TP_MARKER=
VITE_TP_TRS=
