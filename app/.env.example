# Where the SiftPlace FastAPI backend is reachable.
# Dev default below; set to your deployed URL in production.
VITE_API_URL=http://localhost:8000

# Optional Cloudflare Turnstile human check on searches (pairs with the
# backend's TURNSTILE_SECRET_KEY). Leave empty to disable — the app never
# requires an account either way.
VITE_TURNSTILE_SITE_KEY=
